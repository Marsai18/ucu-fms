# Local development — use the same port the backend prints (default 5000; if PORT is set in fleet_backend/.env, match it here).
VITE_API_URL=http://localhost:5000/api

# Optional: Vite dev server proxies /api → this URL so you can set VITE_API_URL=/api and ignore port drift (see vite.config.js).
# API_PROXY_TARGET=http://localhost:5000

# Vercel / production — public Railway (or other) API base URL (must include /api)
# VITE_API_URL=https://your-service.up.railway.app/api

# MySQL (optional — backend loads this file + fleet_backend/.env)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=ucu_fleet_management
